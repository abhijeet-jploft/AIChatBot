PORT=5000
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
REACT_APP_API_URL=http://localhost:5000/api

# ElevenLabs voice responses and custom voice training (optional).
# Pre-made voices (professional/corporate/sales) are built-in; only API key is required.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_PROFILE=professional
ELEVENLABS_MAX_TTS_CHARACTERS=650

# Scraper (optional)
# SCRAPER_MAX_PAGES=300

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ai_chatbot
PG_USER=postgres
PG_PASSWORD=your_postgres_password_here

# Lead notification email (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
LEAD_NOTIFICATION_FROM=leads@example.com
