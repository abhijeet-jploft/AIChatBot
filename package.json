{
  "name": "ai-chatbot",
  "version": "1.0.0",
  "description": "AI Chat Agent - MERN stack with Anthropic API and company-specific training",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "server": "nodemon server/server.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install:all": "npm install && cd client && npm install",
    "migrate": "node -e \"require('dotenv').config(); require('./server/db/migrate').migrate().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\""
  },
  "keywords": [
    "chatbot",
    "anthropic",
    "mern",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.4"
  }
}
